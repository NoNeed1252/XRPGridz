{
  "version": 2,
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share-render?id=:id" },
    { "source": "/api/share-upload", "destination": "/api/share-upload" },
    { "source": "/api/proxy", "destination": "/proxy.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
